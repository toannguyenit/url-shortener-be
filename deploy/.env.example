# Production — URL Shortener (Option A: infra riêng, tách khỏi dự án portfolio khác)
# Copy to VPS: /opt/url-shortener/.env

# === Domains ===
DOMAIN=yourdomain.com
API_URL=https://api.yourdomain.com
SHORT_URL_BASE=https://s.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# === Secrets ===
JWT_SECRET=change-me-openssl-rand-base64-48

# === Docker images (GHCR) ===
GHCR_OWNER=your-github-username
IMAGE_TAG=latest

# === MongoDB (database riêng trong MongoDB container riêng) ===
MONGO_DB=urlshortener

# === RabbitMQ (user + vhost riêng cho dự án này) ===
RABBITMQ_USER=urlshortener
RABBITMQ_PASSWORD=change-me-rabbitmq-password
RABBITMQ_VHOST=urlshortener

# === Nginx ports (đổi nếu nhiều dự án cùng VPS, mỗi dự án domain riêng thì giữ 80/443) ===
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Infra hosts (container names — không đổi trừ khi đổi tên trong infra/docker-compose.yml)
# MONGO_HOST=urlshortener-mongodb
# REDIS_HOST=urlshortener-redis
# RABBITMQ_HOST=urlshortener-rabbitmq
